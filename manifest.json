{
  "manifest_version": 3,
  "name": "Volume Gesture - Video Navigator",
  "version": "4.0.0",
  "description": "Navigate between videos with headset volume buttons. Volume Up→Down = next video, Down→Up = previous. Works when minimized.",
  "permissions": [
    "storage",
    "nativeMessaging",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Volume Gesture Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
